{
  "name": "nosim-collector",
  "version": "3.12.0",
  "description": "노심 매출 수집기 — 배달 플랫폼·POS 매출 자동 수집 (Windows)",
  "main": "main.js",
  "author": "ApronLabs",
  "scripts": {
    "start": "electron .",
    "dashboard": "electron . --dashboard",
    "build": "electron-builder --win --mac",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:dir": "electron-builder --dir",
    "rebuild": "electron-rebuild"
  },
  "dependencies": {
    "dotenv": "~17.3.1",
    "electron-log": "~5.3.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.3.9",
    "node-global-key-listener": "^0.3.0",
    "rebrowser-puppeteer-core": "^24.8.1",
    "serialport": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "~40.6.1",
    "electron-builder": "~25.1.8"
  },
  "build": {
    "appId": "com.semicolon.barcode-scanner",
    "productName": "노심 매출 수집기",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "scripts/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/serialport/**",
      "**/node_modules/@serialport/**",
      "scripts/poc-*.js",
      "scripts/lib/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.business"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ApronLabs",
        "repo": "nosim-collector"
      }
    ],
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "노심 매출 수집기"
    }
  }
}
